#!/usr/bin/env bash
set -e

if [[ "$1" ]]; then quietly "sleep $1"; fi

if [[ "$whereami" == 'darwin' ]]; then
  osascript -e 'tell app "loginwindow" to «event aevtrsdn»'
elif [[ "$whereami" == 'linux' ]]; then
  sudo shutdown -h now
elif [[ "$whereami" == *'bsd' ]]; then
  sudo shutdown -p now
elif [[ "$whereami" == 'windows' ]]; then
  shutdown -p
else
  sudo reboot -p
fi
