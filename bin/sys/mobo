#!/usr/bin/env bash
set -e

if type system_profiler &>/dev/null; then
  echo `sysctl -n machdep.cpu.brand_string; system_profiler SPHardwareDataType \
    | grep "Model Identifier" | $awk '{print $3}'`
elif type wmic &>/dev/null; then wmic baseboard get product,Manufacturer
elif type dmidecode &>/dev/null; then sudo dmidecode -s system-product-name; fi
