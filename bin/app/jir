#!/usr/bin/env bash
set -e

if [[ ! "$jira_base_url" ]]; then echo 'required: jira_base_url'; exit; fi

if [[ "$1" == 'api' ]]; then shift
  if [[ "${jira_email:-}" && "${jira_token:-}" && "${jira_project:-}" ]]; then
    while [[ "$1" ]]; do
      echo -e "\n# ${jira_project}-${1}"
      curl -sS --fail-with-body --connect-timeout 5 --max-time 20 -u "${jira_email}:${jira_token}" -H "Accept: application/json" \
        "${jira_base_url%/}/rest/api/3/issue/${jira_project}-${1}" | jirfmt
      shift
    done
  else
    echo 'vars required: jira_project jira_email jira_token'
  fi
elif [[ "$1" ]]; then
  while [[ "$1" ]]; do item="$1" item="${item//,/}"; shift
    if [[ "$item" =~ .*-.* ]]; then
      open "$jira_base_url/browse/$item"
    elif is int "$item"; then
      open "$jira_base_url/browse/${jira_project}-${item}"
    elif [[ ! "$1" ]]; then
      open "$jira_base_url/browse/$item"
    else
      jira_project="$item"
    fi
  done
else
  open "$jira_base_url"
fi
