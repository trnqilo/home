#!/usr/bin/env python3
import sys, json

def parse_input_or_exit():
  try:
    return json.load(sys.stdin)
  except Exception as e:
    sys.exit(f"failed to parse JSON: {e}")

def check_for_api_errors(data):
  if isinstance(data, dict) and 'errorMessages' in data:
    for msg in data['errorMessages']:
      print(msg, file=sys.stderr)
    sys.exit(1)

def extract_adf_text(node):
  if not isinstance(node, dict):
    return node if isinstance(node, str) else ""

  text = node.get("text", "")
  children = "".join(extract_adf_text(c) for c in node.get("content", []) or [])
  suffix = "\n" if node.get("type") in ("paragraph", "heading", "listItem") else ""

  return f"{text}{children}{suffix}"

def get_field_name(obj, key="name", default="None"):
  return obj.get(key, default) if isinstance(obj, dict) else default

def format_subtasks(subtasks):
  if not subtasks:
    return "  (None)"
  return "\n".join(f"  - [{s['fields']['status']['name']}] {s['key']}: {s['fields']['summary']}" for s in subtasks)

def run_formatter():
  data = parse_input_or_exit()
  check_for_api_errors(data)

  f = data.get("fields", {})

  summary = f.get("summary", "N/A")
  status = get_field_name(f.get("status"))
  priority = get_field_name(f.get("priority"))
  assignee = get_field_name(f.get("assignee"), key="displayName", default="Unassigned")

  labels = ", ".join(f.get("labels", [])) or "None"
  fix_versions = ", ".join(v.get("name") for v in f.get("fixVersions", [])) or "None"

  desc_raw = f.get("description")
  description = extract_adf_text(desc_raw).strip() if desc_raw else "empty"
  tasks = format_subtasks(f.get("subtasks", []))

  output = (
    f"[{data.get('key', 'UNTICKETED')}] {summary}\n"
    f"{'='*40}\n"
    f"Status:   {status} | Priority: {priority}\n"
    f"Assignee: {assignee}\n"
    f"Labels:   {labels}\n"
    f"Fix Ver:  {fix_versions}\n"
    f"{'-'*40}\n"
    f"Description:\n{description}\n"
    f"{'-'*40}\n"
    f"Sub-tasks:\n{tasks}"
  )
  print(output)

if __name__ == "__main__":
  run_formatter()
