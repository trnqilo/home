#!/usr/bin/env bash
set -e

if [[ ! "$1" ]]; then screen -ls; exit
elif [[ "$1" == 'wipe' ]]; then
  ps aux | grep '[S]CREEN' | $awk '{print $2}' \
    | while read pid; do kill -15 $pid; done
  ps aux | grep '[S]CREEN' | $awk '{print $2}' \
    | while read pid; do kill -9 $pid; done
  rm -fv "$HOME"/.screen/*
  exit
elif [[ "$1" =~ ^a(ttach)?$ ]]; then shift; screen -x "$@"; exit
elif [[ "$1" =~ ^d(etach)?$ ]]; then detach='-d'; shift; fi

args+=" $detach -m -S"
if [[ "$1" && ! "$label" ]]; then label="$@"; label=${label// /_}; fi

if screen -ls | grep -q "$label"; then
  [[ "$detach" ]] || screen -x "$label"
else
  screen $args "$label" "$@"
fi
