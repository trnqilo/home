#!/usr/bin/env bash
set  -e

function _firewall_linux { local op="${1:-s}"
  if [[ "$op" =~ ^s(tatus)?$ ]]; then op='status numbered'
  elif [[ "$op" =~ ^r(ez)?$ ]]; then op='reload'
  elif [[ "$op" =~ ^up?$ ]]; then op='enable'
  elif [[ "$op" =~ ^d(own)?$ ]]; then op='disable'
  elif [[ "$op" =~ ^e(dit)?$ ]]; then
    sudo vim /etc/ufw/before.rules; exit
  else op="$@"; fi
  sudo ufw $op
}

_firewall_$whereami $@
