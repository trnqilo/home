#!/usr/bin/env bash

get_volume() {
  osascript -e "output volume of (get volume settings)"
}

set_volume() {
  osascript -e "set volume output volume $1"
}

print_status() {
  local vol=$(get_volume)
  if [[ "$vol" -eq 0 ]]; then
    echo "🔇 Sound MUTED"
  else
    echo "🔊 Sound ON"
  fi
}

mute_vol() {
  local vol=$(get_volume)
  set_volume 0
  echo "🔇 Sound MUTED"
}

unmute_vol() {
  set_volume ${VOL:-50}
  echo "🔊 Sound ON"
}

toggle_vol() {
  local un vol=$(get_volume)
  if [[ "$vol" == 0 ]]; then un=un; fi
  ${un}mute_vol
}

case "${1:-status}" in
  status)  print_status ;;
  toggle)  toggle_vol ;;
  mute)    mute_vol ;;
  unmute)  unmute_vol ;;
  t)       toggle_vol ;;
  m)       mute_vol ;;
  u)       unmute_vol ;;
  *)
    echo "Usage: `basename $0` [toggle|mute|unmute]"
    exit 1 ;;
esac
