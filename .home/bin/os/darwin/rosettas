function _rosettas_ {
  if ls /Library/Apple/System/Library/Receipts | grep -i 'rosetta' &>/dev/null; then
    pgrep oahd && echo 'rosetta is running.' || echo 'rosetta stopped.'
  else
    echo 'rosetta not installed.'
  fi
}

"_rosettas_${1}"
